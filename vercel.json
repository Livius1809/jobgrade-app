{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/executor",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/signals",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/retry",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/maintenance",
      "schedule": "15 */2 * * *"
    }
  ],
  "headers": [],
  "rewrites": [],
  "redirects": []
}
