{
  "name": "jobgrade-desktop",
  "version": "1.0.0",
  "description": "JobGrade Desktop — Evaluare și ierarhizare posturi",
  "main": "main.js",
  "author": "Psihobusiness Consulting SRL",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "ro.jobgrade.desktop",
    "productName": "JobGrade",
    "copyright": "© 2026 Psihobusiness Consulting SRL",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns",
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "shortcutName": "JobGrade"
    }
  }
}
