# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
# Înlocuiește cu URL-ul tău PostgreSQL (Supabase / Neon / local)
DATABASE_URL="postgresql://postgres:password@localhost:5432/jobgrade"

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="JobGrade"

# ─────────────────────────────────────────
# AUTH (NextAuth)
# ─────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="schimba-cu-un-secret-random-de-minim-32-caractere"

# ─────────────────────────────────────────
# OAUTH (opțional)
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# ─────────────────────────────────────────
# AI — Anthropic Claude
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─────────────────────────────────────────
# REDIS (Upstash)
# ─────────────────────────────────────────
UPSTASH_REDIS_URL=""
UPSTASH_REDIS_TOKEN=""

# ─────────────────────────────────────────
# STORAGE (AWS S3 / Cloudflare R2)
# ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME="jobgrade-files"
AWS_REGION="eu-central-1"

# ─────────────────────────────────────────
# EMAIL (Resend)
# ─────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@jobgrade.ro"

# ─────────────────────────────────────────
# STRIPE
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─────────────────────────────────────────
# INTERNAL API (KB routes, n8n workflows)
# ─────────────────────────────────────────
# Generează cu: openssl rand -hex 32
INTERNAL_API_KEY=""

# ─────────────────────────────────────────
# ELEVENLABS (Voice)
# ─────────────────────────────────────────
# Agent IDs — create in ElevenLabs Conversational AI dashboard
# Configure Custom LLM URL: https://your-domain.com/api/v1/voice/completions
# Set model name to agent role: soa, cssa, or csa
NEXT_PUBLIC_ELEVENLABS_AGENT_SOA=""
NEXT_PUBLIC_ELEVENLABS_AGENT_CSSA=""
NEXT_PUBLIC_ELEVENLABS_AGENT_CSA=""
# Voice IDs (optional — configure in ElevenLabs dashboard)
NEXT_PUBLIC_ELEVENLABS_VOICE_B2B=""
NEXT_PUBLIC_ELEVENLABS_VOICE_B2C=""

# ─────────────────────────────────────────
# OBLIO.EU (facturare + chitante)
# ─────────────────────────────────────────
OBLIO_CLIENT_ID=""
OBLIO_CLIENT_SECRET=""
OBLIO_CIF=""

# ─────────────────────────────────────────
# MONITORING
# ─────────────────────────────────────────
SENTRY_DSN=""
