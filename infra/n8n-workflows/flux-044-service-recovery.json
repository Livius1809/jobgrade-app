{
  "name": "FLUX-044 Service Recovery",
  "nodes": [
    {
      "parameters": { "path": "flux-044-recovery", "httpMethod": "POST" },
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.WEBHOOK_URL }}/api/v1/disfunctions/remediate",
        "headerParametersJson": "{ \"x-internal-key\": \"{{ $env.INTERNAL_API_KEY }}\" }",
        "bodyParametersJson": "={{ JSON.stringify($json.body) }}",
        "options": { "timeout": 60000 }
      },
      "name": "Remediate",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 300]
    }
  ],
  "connections": { "Webhook Trigger": { "main": [[{ "node": "Remediate", "type": "main", "index": 0 }]] } },
  "active": true,
  "settings": { "executionOrder": "v1" }
}
