{
  "name": "FLUX-041 Healthcheck Bridge",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{ "field": "cronExpression", "expression": "*/5 * * * *" }] } },
      "name": "Cron 5min",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.WEBHOOK_URL }}/api/v1/health/heartbeat",
        "headerParametersJson": "{ \"x-internal-key\": \"{{ $env.INTERNAL_API_KEY }}\" }",
        "options": { "timeout": 15000 }
      },
      "name": "Heartbeat",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 300]
    }
  ],
  "connections": { "Cron 5min": { "main": [[{ "node": "Heartbeat", "type": "main", "index": 0 }]] } },
  "active": true,
  "settings": { "executionOrder": "v1" }
}
