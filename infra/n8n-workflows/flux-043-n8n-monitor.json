{
  "name": "FLUX-043 n8n Execution Monitor",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{ "field": "cronExpression", "expression": "*/10 * * * *" }] } },
      "name": "Cron 10min",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.WEBHOOK_URL }}/api/v1/monitors/n8n-executions",
        "headerParametersJson": "{ \"x-internal-key\": \"{{ $env.INTERNAL_API_KEY }}\" }",
        "options": { "timeout": 30000 }
      },
      "name": "Check Executions",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 300]
    }
  ],
  "connections": { "Cron 10min": { "main": [[{ "node": "Check Executions", "type": "main", "index": 0 }]] } },
  "active": true,
  "settings": { "executionOrder": "v1" }
}
