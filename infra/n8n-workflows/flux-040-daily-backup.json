{
  "name": "FLUX-040 Daily Backup",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{ "field": "cronExpression", "expression": "0 3 * * *" }] } },
      "name": "Cron 03:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.WEBHOOK_URL }}/api/v1/admin/backup",
        "headerParametersJson": "{ \"x-internal-key\": \"{{ $env.INTERNAL_API_KEY }}\" }",
        "options": { "timeout": 300000 }
      },
      "name": "Backup",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 300]
    }
  ],
  "connections": { "Cron 03:00": { "main": [[{ "node": "Backup", "type": "main", "index": 0 }]] } },
  "active": true,
  "settings": { "executionOrder": "v1" }
}
