{
  "name": "FLUX-046 Daily Summary Notify",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{ "field": "cronExpression", "expression": "0 18 * * *" }] } },
      "name": "Cron 18:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.WEBHOOK_URL }}/api/v1/disfunctions/daily-summary",
        "headerParametersJson": "{ \"x-internal-key\": \"{{ $env.INTERNAL_API_KEY }}\" }",
        "options": { "timeout": 60000 }
      },
      "name": "Daily Summary",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 300]
    }
  ],
  "connections": { "Cron 18:00": { "main": [[{ "node": "Daily Summary", "type": "main", "index": 0 }]] } },
  "active": true,
  "settings": { "executionOrder": "v1" }
}
