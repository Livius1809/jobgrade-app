// ── Agent Registry Enums ─────────────────────────────────────────────────────

enum AgentLevel {
  STRATEGIC
  TACTICAL
  OPERATIONAL
}

/// Mod de activitate așteptat al unui agent.
///
/// Folosit de FLUX-045 (role-activity monitor) pentru a calibra ce înseamnă
/// "lipsă de activitate" pentru fiecare agent. Diferite moduri implică praguri
/// și semnale diferite — un agent REACTIVE_TRIGGERED care stă 72h fără activitate
/// e comportament normal, nu disfuncție.
enum AgentActivityMode {
  /// Agent cu ciclu propriu de activitate (cron la cycleIntervalHours).
  /// Detectorul raportează `no_cycles_in_Xh` dacă nu rulează la ritmul așteptat.
  /// Ex: COG, manageri proactivi (CCO, COCSA, PMA, CFO, CMA...).
  PROACTIVE_CYCLIC

  /// Agent activat la trigger extern (cerere client, alertă, audit, escaladare).
  /// Detectorul NU raportează `no_activity_in_Xh` — absența e starea normală.
  /// Pe viitor, va măsura latența de răspuns la triggere (dar nu acum).
  /// Ex: DPO, CJA, CIA, CCIA, SAFETY_MONITOR, echipa L2 Suport (PSE, PSYCHOLINGUIST, PPMO, STA, SOC, SCA, PPA).
  REACTIVE_TRIGGERED

  /// Agent executor care așteaptă delegare funcțională de la managerul său.
  /// Detectorul NU raportează absența — e stare așteptată până la activarea
  /// mecanismului de delegare (Calea 1, sprint viitor de orchestrare execuție).
  /// Ex: ACA, BCA, BDA, FDA, MAA, QAA, SQA etc. (agenți operaționali executori).
  DORMANT_UNTIL_DELEGATED

  /// Agent cu comportament mixt (are cicluri proprii DAR și răspunde la triggere).
  /// Detectorul aplică ambele verificări; rezerva pentru cazuri speciale.
  /// Ex: SOA (are cicluri proprii de prospecting ȘI răspunde la lead-uri primite).
  HYBRID

  /// Agent pauzat explicit de Owner până la rezolvarea unui gap cunoscut.
  /// Endpoint-ul /agents/cycle NU rulează ciclul lui. Detectorul NU raportează.
  /// Motivul trebuie documentat în memorie (ce gap, când se reia).
  /// Ex: EMA/CCO/QLA pauzați 05.04.2026 pending Calea 1 (delegare executor).
  PAUSED_KNOWN_GAP
}

