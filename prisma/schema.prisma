// ─────────────────────────────────────────
// PRICING & TELEMETRY (16.04.2026)
// Algoritm: cost real → cost acoperitor → BNR+buffer → marjă
// Vezi: project_pricing_methodology.md
// Valorile concrete (cost, marjă, buffer) populate de COG după
// răspunsul la cele 8 întrebări strategice.
// ─────────────────────────────────────────

model ProviderCost {
  id               String   @id @default(cuid())
  provider         String   // "anthropic", "vercel", "neon", "resend", etc.
  resourceType     String   // "haiku-4-5-input-tokens", "vercel-pro-monthly", "neon-launch-monthly", etc.
  unitMeasure      String   // "1M tokens", "1 month subscription", "1 client/month", "1 minute compute"
  costCategory     String   @default("OPEX_PER_EXECUTION")
  // CAPEX: lunar fix indiferent de volum (plan Vercel Pro, Neon Launch, salarii, marketing)
  // OPEX_PER_CLIENT: incremental per cont nou activat (storage profil, backup, notificări baseline)
  // OPEX_PER_EXECUTION: variabil per rulare/sesiune (tokens AI, compute, email, blob)
  currentCostUSD   Decimal  @db.Decimal(20, 8) // preț real curent (informativ)
  coveringCostUSD  Decimal  @db.Decimal(20, 8) // preț acoperitor (folosit la calcul — worst case)
  notes            String?  @db.Text           // de ce e ales acest covering
  effectiveFrom    DateTime @default(now())
  updatedBy        String?                     // OWNER, COG, AUTOMATED_JOB
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([provider, resourceType, effectiveFrom])
  @@index([provider, resourceType])
  @@index([costCategory])
  @@map("provider_costs")
}

model AIOperationTier {
  id                       String   @id @default(cuid())
  operationType            String   @unique // "intent-classification", "report-generation-je", etc.
  description              String?  @db.Text
  currentModel             String   // "claude-haiku-4-5-20251001"
  coveringModel            String   // "claude-opus-4-6" (folosit la calcul cost)
  tokenAmplificationFactor Decimal  @default(1.0) @db.Decimal(5, 2) // 1.0-2.0 (Opus poate genera mai mult)
  notes                    String?  @db.Text
  effectiveFrom            DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("ai_operation_tiers")
}

model ServiceUsageLog {
  id                  String   @id @default(cuid())
  tenantId            String
  userId              String?
  serviceCode         String   // ID serviciu (ex: "je-evaluate", "consultant-hr-chat")
  executionVariant    String   @default("AUTO") // "AUTO" | "HYBRID_AI_MEDIATED" | "HYBRID_HUMAN_MEDIATED"
  executionId         String?  // ID execuție (sesiune chat, raport, etc.)
  operationType       String?  // mapare la AIOperationTier (dacă e operație AI)

  // Telemetry brut
  modelUsed           String?  // model AI efectiv folosit
  tokensInput         Int      @default(0)
  tokensOutput        Int      @default(0)
  computeMs           Int      @default(0)
  dbReadBytes         Int      @default(0)
  dbWriteBytes        Int      @default(0)
  bandwidthBytes      Int      @default(0)
  emailsSent          Int      @default(0)
  blobBytes           Int      @default(0)
  humanMinutes        Decimal  @default(0) @db.Decimal(8, 2) // pentru servicii mixte cu uman

  // Cost calculat
  costRealRON         Decimal? @db.Decimal(12, 4) // costul real (informativ)
  costCoveringRON     Decimal? @db.Decimal(12, 4) // costul acoperitor (folosit pentru margin)
  creditsCharged      Decimal? @db.Decimal(10, 4) // credite debitate efectiv

  metadata            Json?    // payload suplimentar (ex: durata sesiune chat)
  createdAt           DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([serviceCode, createdAt])
  @@index([userId, createdAt])
  @@map("service_usage_logs")
}

model ServicePricing {
  id                 String   @id @default(cuid())
  serviceCode        String   // "je-evaluate", "pay-gap-report", "consultant-hr-chat", etc.
  serviceName        String
  serviceType        String   // "REPORT" | "ASSISTANCE" | "PROCESS"
  // Variantă execuție — același serviciu poate avea 1-3 variante cu cost și
  // preț distinct (AUTO, HYBRID_AI_MEDIATED, HYBRID_HUMAN_MEDIATED).
  // Folosit de servicii de tip evaluare (JE, evaluare comună, mediere decalaj).
  executionVariant   String   @default("AUTO") // "AUTO" | "HYBRID_AI_MEDIATED" | "HYBRID_HUMAN_MEDIATED"
  unitMeasure        String   // "rulare", "minut", "intrebare", "sesiune", "angajat", "pozitie"
  // Tarifare mixtă CAPEX+OPEX:
  // costInCredits = baza fixă (componenta CAPEX — setup, framework, infrastructură)
  // perUnitCredits = variabila per unitate (componenta OPEX — scalează cu volumul)
  // Formula: total = costInCredits + perUnitCredits × cantitate
  // Dacă costInCredits = 0 → pur OPEX (doar per unitate)
  // Dacă perUnitCredits = 0/null → preț fix per proiect (pur CAPEX sau preț flat)
  costInCredits      Decimal  @db.Decimal(10, 4) // baza fixă (credite)
  perUnitCredits     Decimal? @db.Decimal(10, 4) // variabil per unitate (credite) — null = preț fix
  perUnitLabel       String?  // denumire unitate variabilă (ex: "angajat", "poziție") — pt afișare
  marginMultiplier   Decimal? @db.Decimal(5, 2)  // factor multiplicare cost intern → preț (informativ)
  chatTier           String?  // "FAMILIARIZARE" | "CONSULTANTA" (doar pentru ASSISTANCE)
  isFreeTier         Boolean  @default(false)
  freeTierLimit      Int?
  freeTierUnit       String?
  effectiveFrom      DateTime @default(now())
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([serviceCode, executionVariant, chatTier, effectiveFrom])
  @@index([serviceCode])
  @@index([serviceCode, executionVariant])
  @@map("service_pricing")
}

model CreditValue {
  id                  String   @id @default(cuid())
  bnrUsdRonRate       Decimal  @db.Decimal(10, 4) // cursul BNR USD→RON la data efectiva
  bnrEurRonRate       Decimal? @db.Decimal(10, 4) // cursul BNR EUR→RON (pentru furnizori EUR)
  bufferPercent       Decimal  @default(5.0) @db.Decimal(5, 2) // buffer peste BNR (decizie COG)
  effectiveUsdRonRate Decimal  @db.Decimal(10, 4) // BNR × (1 + buffer/100) — folosit la conversie
  valuePerCreditRON   Decimal  @db.Decimal(8, 4)  // RON per 1 credit (decizie COG)
  effectiveFrom       DateTime @default(now())
  notes               String?  @db.Text
  createdAt           DateTime @default(now())

  @@map("credit_values")
}

// ─────────────────────────────────────────
// ORGANISM INTELLIGENT — CRONURI INTELIGENTE
// Arhitectura: threshold → KB-first → alignment → cost-gate → executor → learning → telemetry
// ─────────────────────────────────────────

model ExecutionTelemetry {
  id                String   @id @default(cuid())
  taskId            String?
  agentRole         String
  taskType          String?
  modelUsed         String   // "haiku" | "sonnet" | "opus"
  tokensInput       Int      @default(0)
  tokensOutput      Int      @default(0)
  estimatedCostUSD  Float    @default(0)
  kbHit             Boolean  @default(false)
  kbSimilarityScore Float?
  alignmentResult   String   @default("SKIPPED") // ALIGNED | UNCERTAIN | MISALIGNED | SKIPPED
  alignmentLevel    Int?     // 1-5 la ce nivel s-a rezolvat alinierea
  thresholdPassed   Boolean  @default(true)
  durationMs        Int      @default(0)
  webSearchCount    Int      @default(0)
  learningCreated   Boolean  @default(false)
  isInternal        Boolean  @default(true) // true = consum organism, false = consum client
  createdAt         DateTime @default(now())

  @@index([agentRole, createdAt])
  @@index([createdAt])
  @@map("execution_telemetry")
}

model LearningArtifact {
  id                  String   @id @default(cuid())
  problemClass        String   // clasificare problema (ex: "alignment-check", "kb-gap", "escalation-pattern")
  rule                String   @db.Text // regula extrasa
  example             String   @db.Text // exemplu concret
  antiPattern         String?  @db.Text // ce NU trebuie facut
  sourceEscalationId  String?  // task-ul care a generat artefactul
  teacherRole         String   // cine a produs artefactul (agentul care a rezolvat)
  studentRole         String   // cui i-a fost livrat (agentul care a escalat)
  sourceType          String   @default("ESCALATION") // ESCALATION | POST_EXECUTION | EXTRAPOLATION
  appliedCount        Int      @default(0) // de cate ori a fost aplicat cu succes
  effectivenessScore  Float    @default(0) // 0-1, creste cu fiecare aplicare reusita
  validated           Boolean  @default(false) // true = folosit cu succes în task aprobat de manager
  expiresAt           DateTime? // expirare daca nu e folosit >90 zile
  businessId          String    @default("shared") // "shared" = CPU core, "biz_jobgrade" = business-specific
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([studentRole, problemClass])
  @@index([teacherRole])
  @@index([businessId])
  @@map("learning_artifacts")
}

model AgentBudget {
  id                 String   @id @default(cuid())
  agentRole          String   @unique
  dailyLimitTokens   Int      @default(20000)
  monthlyLimitTokens Int      @default(500000)
  alertThreshold     Float    @default(0.8) // 80% din limita
  currentDailyUsed   Int      @default(0)
  currentMonthlyUsed Int      @default(0)
  lastResetDaily     DateTime @default(now())
  lastResetMonthly   DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("agent_budgets")
}

model AlignmentLog {
  id              String   @id @default(cuid())
  taskId          String?
  agentRole       String
  actionSummary   String   @db.Text // ce voia sa faca
  level           Int      // 1-5: la ce nivel s-a rezolvat
  result          String   // ALIGNED | UNCERTAIN | MISALIGNED | EXTRAPOLATED
  resolvedBy      String?  // agentRole care a rezolvat (daca escalat/extrapolat)
  reasoning       String?  @db.Text // justificare
  artifactCreated Boolean  @default(false) // a generat LearningArtifact
  costTokens      Int      @default(0) // tokens consumate pentru verificare (0 la Nivel 1-3)
  createdAt       DateTime @default(now())

  @@index([agentRole, createdAt])
  @@index([level, result])
  @@map("alignment_logs")
}

