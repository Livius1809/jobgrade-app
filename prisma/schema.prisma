model PayrollEntry {
  id            String @id @default(cuid())
  tenantId      String
  importBatchId String // grup de import (un upload = un batch)

  // Identificare post
  jobCode        String // cod post intern companie
  jobTitle       String // denumire post
  department     String // departament
  hierarchyLevel String // N, N-1, N-2, N-3, N-4, N-5+
  jobFamily      String // familie posturi (Financiar, IT, Vânzări)

  // Grad/Clasă — dual: calculat + evaluat
  gradeCalculated Int? // grad auto-calculat din clustering
  gradeEvaluated  Int? // grad din evaluare 6 criterii (după JE)

  // Remunerație completă
  baseSalary        Float // salariu bază brut RON/lună
  fixedAllowances   Float @default(0) // sporuri fixe RON/lună
  annualBonuses     Float @default(0) // bonusuri/prime RON/an
  annualCommissions Float @default(0) // comisioane RON/an
  benefitsInKind    Float @default(0) // beneficii natură RON echiv/lună
  mealVouchers      Float @default(0) // tichete masă/vacanță RON/lună

