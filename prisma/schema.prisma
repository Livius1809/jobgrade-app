model AgentDefinition {
  id          String     @id @default(cuid())
  agentRole   String     @unique
  displayName String
  description String     @db.Text
  level       AgentLevel
  isManager   Boolean    @default(false)
  isActive    Boolean    @default(true)

  // Mod de activitate — folosit de detectorul de disfuncții pentru a calibra
  // ce înseamnă "lipsă de activitate" pentru fiecare agent. Vezi
  // project_disfunction_detection_principle.md (05.04.2026).
  activityMode AgentActivityMode @default(PROACTIVE_CYCLIC)

  // Manager-specific
  cycleIntervalHours Int?
  objectives         String[]
  thresholds         Json?

  // Cold start config
  coldStartDescription String?  @db.Text
  coldStartPrompts     String[]

  // Propagation rules (outgoing edges)
  propagationTargets Json?

  // Metadata
  createdBy String   @default("SYSTEM")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parentRelations AgentRelationship[] @relation("ChildAgent")
  childRelations  AgentRelationship[] @relation("ParentAgent")
  proposals       OrgProposal[]       @relation("ProposalAgent")
  metrics         AgentMetric[]

  @@index([level, isActive])
  @@map("agent_definitions")
}

model AgentRelationship {
