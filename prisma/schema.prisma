generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// TENANCY & AUTH
// ─────────────────────────────────────────

model Tenant {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  plan             Plan         @default(STARTER)
  isPilot          Boolean      @default(false)
  locale           String       @default("ro")
  status           TenantStatus @default(ACTIVE)
  stripeCustomerId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  users                 User[]
  company               CompanyProfile?
  departments           Department[]
  jobs                  Job[]
  sessions              EvaluationSession[]
  compensationPkgs      CompensationPackage[]
  kpiDefinitions        KpiDefinition[]
  simulations           SimulationScenario[]
  aiGenerations         AiGeneration[]
  reports               Report[]
  credits               CreditBalance?
  creditTxns            CreditTransaction[]
  salaryGrades          SalaryGrade[]
  employeeSalaryRecords EmployeeSalaryRecord[]
  payGapReports         PayGapReport[]
  jointAssessments      JointPayAssessment[]
  employeeRequests      EmployeeRequest[]
  clientMemories        ClientMemory[]
  payrollEntries        PayrollEntry[]
  payrollImportBatches  PayrollImportBatch[]
  revenueEntries        RevenueEntry[]
  servicePurchase       ServicePurchase?
  userOrgRoles          UserOrgRole[]
  continuousReports     EmployeeContinuousReport[]
  guideJournalEntries   GuideJournalEntry[]

  @@map("tenants")
}

model User {
  id           String     @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String?
  firstName    String
  lastName     String
  jobTitle     String?
  role         UserRole   @default(REPRESENTATIVE)
  locale       String     @default("ro")
  lastLogin    DateTime?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  accounts               Account[]
  authSessions           AuthSession[]
  sessionParticipants    SessionParticipant[]
  jobAssignments         JobAssignment[]
  votes                  Vote[]
  facilitatorDecisions   FacilitatorDecision[]
  clarificationQuestions ClarificationQuestion[]
  clarificationAnswers   ClarificationAnswer[]
  overrides              ScoreOverride[]
  notifications          Notification[]
  representedJobs        Job[]                   @relation("JobRepresentative")
  validatedSessions      EvaluationSession[]     @relation("sessionValidator")
  discussionComments     DiscussionComment[]
  memberValidations      MemberValidation[]

  orgRoles          UserOrgRole[]

  @@unique([tenantId, email])
  @@map("users")
}

// ── Roluri organizaționale per user (many-to-many) ──────────────────────────

model UserOrgRole {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String
  orgRole    OrgRole
  assignedBy String?  // userId care a alocat rolul
  assignedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, orgRole])
  @@index([tenantId, orgRole])
  @@map("user_org_roles")
}

// ── Matrice permisiuni (seed-uită, nu editabilă de client) ──────────────────

model PermissionRule {
  id        String       @id @default(cuid())
  orgRole   OrgRole
  resource  PermResource
  action    PermAction
  minLayer  Int          @default(0) // 0 = fără layer, 1-4 = layer minim necesar
  condition String?      // condiție suplimentară (ex: "own" = doar propriile resurse)

  @@unique([orgRole, resource, action])
  @@index([orgRole])
  @@map("permission_rules")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────
// COMPANY PROFILE
// ─────────────────────────────────────────

model CompanyProfile {
  id          String    @id @default(cuid())
  tenantId    String    @unique
  mission     String?   @db.Text
  vision      String?   @db.Text
  values      String[]
  description String?   @db.Text
  industry    String?
  size        String?
  website     String?
  cui         String?
  regCom      String?
  address     String?
  county      String?
  caenCode    String?
  caenName    String?
  isVATPayer  Boolean?
  logoUrl     String?
  extractedAt DateTime?
  anafSyncedAt DateTime?
  // MVV Progressive Builder
  mvvMaturity      String    @default("IMPLICIT") // IMPLICIT | EMERGENT | PARTIAL | SUBSTANTIAL | COMPLETE
  missionDraft     String?   @db.Text // generat AI
  visionDraft      String?   @db.Text
  valuesDraft      String[]
  mvvLastBuiltAt   DateTime?
  mvvLastBuiltFrom String?   // ce date au contribuit la ultimul rebuild
  mvvCoherenceScore Float?   // 0-100
  mvvCoherenceGaps  Json?    // [{level, gap, suggestion}]
  mvvValidatedAt    DateTime? // când a confirmat clientul MVV-ul
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("company_profiles")
}

// Company Profiler Engine — Punct 7: Memorie de evoluție
model CompanyProfileSnapshot {
  id              String    @id @default(cuid())
  tenantId        String
  maturityLevel   String    // IMPLICIT | EMERGENT | PARTIAL | SUBSTANTIAL | COMPLETE
  maturityScore   Float     // 0-100
  coherenceScore  Float     // 0-100
  dataPoints      Json      // DataPointPresence snapshot
  readyServices   String[]  // ServiceType[] active la momentul snapshot-ului
  takenAt         DateTime  @default(now())

  @@index([tenantId, takenAt])
  @@map("company_profile_snapshots")
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[]
  jobs   Job[]

  @@unique([tenantId, name])
  @@map("departments")
}

// ─────────────────────────────────────────
// FIȘE DE POST
// ─────────────────────────────────────────

model Job {
  id               String    @id @default(cuid())
  tenantId         String
  departmentId     String?
  representativeId String?
  title            String
  code             String?
  purpose          String?   @db.Text
  description      String?   @db.Text
  responsibilities String?   @db.Text
  requirements     String?   @db.Text
  status           JobStatus        @default(DRAFT)
  structureType    JobStructureType @default(HUMAN)
  isActive         Boolean          @default(true)
  aiAnalyzed       Boolean          @default(false)
  aiAnalysis       Json?
  createdBy        String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department     Department? @relation(fields: [departmentId], references: [id])
  representative User?       @relation("JobRepresentative", fields: [representativeId], references: [id])

  sessionJobs          SessionJob[]
  compensationPackages CompensationPackage[]
  kpiDefinitions       KpiDefinition[]
  simulations          SimulationScenario[]
  jobResults           JobResult[]

  @@map("jobs")
}

// ─────────────────────────────────────────
// CRITERII (GLOBALE — definite de platformă)
// ─────────────────────────────────────────

model Criterion {
  id          String  @id @default(cuid())
  name        String  @unique
  description String? @db.Text
  category    String?
  order       Int
  isActive    Boolean @default(true)

  subfactors           Subfactor[]
  evaluations          Evaluation[]
  consensusStatuses    ConsensusStatus[]
  votes                Vote[]
  facilitatorDecisions FacilitatorDecision[]
  overrides            ScoreOverride[]
  discussionComments   DiscussionComment[]
  memberValidations    MemberValidation[]

  @@map("criteria")
}

model Subfactor {
  id          String @id @default(cuid())
  criterionId String
  code        String
  description String @db.Text
  points      Int
  order       Int

  criterion            Criterion             @relation(fields: [criterionId], references: [id])
  evaluations          Evaluation[]
  votes                Vote[]
  facilitatorDecisions FacilitatorDecision[]
  overrides            ScoreOverride[]
  consensuses          ConsensusStatus[]

  @@unique([criterionId, code])
  @@map("subfactors")
}

// ─────────────────────────────────────────
// SESIUNI DE EVALUARE
// ─────────────────────────────────────────

model EvaluationSession {
  id                 String             @id @default(cuid())
  tenantId           String
  name               String
  status             SessionStatus      @default(DRAFT)
  evaluationType     EvaluationType     @default(AI_GENERATED)
  currentRound       Int                @default(1)
  consensusThreshold Float              @default(0.75)
  deadline           DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  validatedAt        DateTime?
  validatedBy        String?
  signatureData      String?            @db.Text // base64 PNG semnătură olografă
  signedAt           DateTime?
  createdById        String             @default("")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  validator User?  @relation("sessionValidator", fields: [validatedBy], references: [id])

  sessionJobs          SessionJob[]
  participants         SessionParticipant[]
  evaluations          Evaluation[]
  consensusStatuses    ConsensusStatus[]
  votes                Vote[]
  facilitatorDecisions FacilitatorDecision[]
  clarifications       ClarificationQuestion[]
  jobResults           JobResult[]
  salaryGrades         SalaryGrade[]
  overrides            ScoreOverride[]
  discussionComments   DiscussionComment[]
  memberValidations    MemberValidation[]

  @@map("evaluation_sessions")
}

model SessionJob {
  id        String   @id @default(cuid())
  sessionId String
  jobId     String
  createdAt DateTime @default(now())

  session     EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id])
  assignments JobAssignment[]

  @@unique([sessionId, jobId])
  @@map("session_jobs")
}

model SessionParticipant {
  id          String    @id @default(cuid())
  sessionId   String
  userId      String
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  session EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@map("session_participants")
}

model JobAssignment {
  id           String    @id @default(cuid())
  sessionJobId String
  userId       String
  submittedAt  DateTime?
  createdAt    DateTime  @default(now())

  sessionJob  SessionJob   @relation(fields: [sessionJobId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  evaluations Evaluation[]

  @@unique([sessionJobId, userId])
  @@map("job_assignments")
}

// ─────────────────────────────────────────
// EVALUARE / SCORARE
// ─────────────────────────────────────────

model Evaluation {
  id            String   @id @default(cuid())
  sessionId     String
  assignmentId  String
  criterionId   String
  subfactorId   String
  justification String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  session    EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assignment JobAssignment     @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  criterion  Criterion         @relation(fields: [criterionId], references: [id])
  subfactor  Subfactor         @relation(fields: [subfactorId], references: [id])

  @@unique([assignmentId, criterionId])
  @@map("evaluations")
}

// ─────────────────────────────────────────
// CLARIFICĂRI
// ─────────────────────────────────────────

model ClarificationQuestion {
  id          String   @id @default(cuid())
  sessionId   String
  jobId       String
  criterionId String
  question    String   @db.Text
  askedBy     String
  createdAt   DateTime @default(now())

  session EvaluationSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  asker   User                 @relation(fields: [askedBy], references: [id])
  answer  ClarificationAnswer?

  @@map("clarification_questions")
}

model ClarificationAnswer {
  id         String   @id @default(cuid())
  questionId String   @unique
  answer     String   @db.Text
  answeredBy String
  createdAt  DateTime @default(now())

  question ClarificationQuestion @relation(fields: [questionId], references: [id])
  answerer User                  @relation(fields: [answeredBy], references: [id])

  @@map("clarification_answers")
}

// ─────────────────────────────────────────
// CONSENS
// ─────────────────────────────────────────

model ConsensusStatus {
  id               String         @id @default(cuid())
  sessionId        String
  jobId            String
  criterionId      String
  status           ConsensusState @default(PENDING)
  round1Cv         Float?
  round2Cv         Float?
  finalSubfactorId String?
  updatedAt        DateTime       @updatedAt

  session        EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  criterion      Criterion         @relation(fields: [criterionId], references: [id])
  finalSubfactor Subfactor?        @relation(fields: [finalSubfactorId], references: [id])

  @@unique([sessionId, jobId, criterionId])
  @@map("consensus_statuses")
}

model Vote {
  id          String   @id @default(cuid())
  sessionId   String
  jobId       String
  criterionId String
  userId      String
  subfactorId String
  round       Int      @default(1)
  createdAt   DateTime @default(now())

  session   EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id])
  criterion Criterion         @relation(fields: [criterionId], references: [id])
  subfactor Subfactor         @relation(fields: [subfactorId], references: [id])

  @@unique([sessionId, jobId, criterionId, userId])
  @@map("votes")
}

model FacilitatorDecision {
  id            String   @id @default(cuid())
  sessionId     String
  jobId         String
  criterionId   String
  facilitatorId String
  subfactorId   String
  rationale     String   @db.Text
  createdAt     DateTime @default(now())

  session     EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  facilitator User              @relation(fields: [facilitatorId], references: [id])
  criterion   Criterion         @relation(fields: [criterionId], references: [id])
  subfactor   Subfactor         @relation(fields: [subfactorId], references: [id])

  @@unique([sessionId, jobId, criterionId])
  @@map("facilitator_decisions")
}

// ─────────────────────────────────────────
// DISCUȚIE GRUP (Bloc 3)
// ─────────────────────────────────────────

model DiscussionComment {
  id          String   @id @default(cuid())
  sessionId   String
  jobId       String
  criterionId String
  userId      String?  // null = AI mediator
  round       Int      @default(1)
  content     String   @db.Text
  isAi        Boolean  @default(false)
  parentId    String?  // reply threading
  createdAt   DateTime @default(now())

  session   EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User?             @relation(fields: [userId], references: [id])
  criterion Criterion         @relation(fields: [criterionId], references: [id])
  parent    DiscussionComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies   DiscussionComment[] @relation("CommentReplies")

  @@index([sessionId, jobId, criterionId])
  @@map("discussion_comments")
}

// ─────────────────────────────────────────
// VALIDARE POST-CONSENS (Bloc 4)
// ─────────────────────────────────────────

model MemberValidation {
  id          String    @id @default(cuid())
  sessionId   String
  jobId       String
  userId      String
  criterionId String
  preScore    String    // litera pre-scorare originală (ex: "D")
  consensus   String    // litera consens final (ex: "E")
  accepted    Boolean   @default(false)
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  session   EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id])
  criterion Criterion         @relation(fields: [criterionId], references: [id])

  @@unique([sessionId, jobId, userId, criterionId])
  @@map("member_validations")
}

// ─────────────────────────────────────────
// REZULTATE & CLASIFICARE
// ─────────────────────────────────────────

model JobResult {
  id              String   @id @default(cuid())
  sessionId       String
  jobId           String
  totalScore      Int
  normalizedScore Float
  rank            Int
  salaryGradeId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  session     EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id])
  salaryGrade SalaryGrade?      @relation(fields: [salaryGradeId], references: [id])

  @@unique([sessionId, jobId])
  @@map("job_results")
}

model SalaryGrade {
  id        String   @id @default(cuid())
  tenantId  String
  sessionId String
  name      String
  scoreMin  Int
  scoreMax  Int
  salaryMin Float?
  salaryMax Float?
  currency  String   @default("RON")
  order     Int
  createdAt DateTime @default(now())

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session               EvaluationSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  jobResults            JobResult[]
  employeeSalaryRecords EmployeeSalaryRecord[]
  employeeRequests      EmployeeRequest[]
  steps                 SalaryStep[]

  @@map("salary_grades")
}

model SalaryStep {
  id            String   @id @default(cuid())
  salaryGradeId String
  step          Int
  name          String
  salary        Decimal
  criteria      String?
  createdAt     DateTime @default(now())

  grade SalaryGrade @relation(fields: [salaryGradeId], references: [id], onDelete: Cascade)

  @@unique([salaryGradeId, step])
  @@index([salaryGradeId, step])
  @@map("salary_steps")
}

// ─────────────────────────────────────────
// PAY GAP ANALYTICS (EU 2023/970 Art. 9)
// ─────────────────────────────────────────

model EmployeeSalaryRecord {
  id            String   @id @default(cuid())
  tenantId      String
  salaryGradeId String?
  employeeCode  String       // cod intern platforma (generat sau din client)
  companyEmployeeId String?  // ID alocat de client (poate fi null inițial)
  internalFingerprint String? // hash din (jobTitle+dept+gender+salary) pt matching fără ID
  gender        Gender
  baseSalary    Float
  variableComp  Float    @default(0)
  department    String?
  jobCategory   String?
  workSchedule  String?  @default("8h") // normă lucru: 2h, 4h, 6h, 8h
  evaluationScore Int?   // scor total din Modul 1 (muncă egală = scor egal)
  periodYear    Int
  periodMonth   Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salaryGrade SalaryGrade? @relation(fields: [salaryGradeId], references: [id])

  @@unique([tenantId, employeeCode, periodYear])
  @@index([tenantId, companyEmployeeId])
  @@index([tenantId, internalFingerprint])
  @@map("employee_salary_records")
}

model PayGapReport {
  id            String       @id @default(cuid())
  tenantId      String
  reportYear    Int
  indicators    Json
  employeeCount Int
  status        ReportStatus @default(DRAFT)
  publishedAt   DateTime?
  generatedAt   DateTime     @default(now())
  generatedBy   String

  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jointAssessments JointPayAssessment[]

  @@unique([tenantId, reportYear])
  @@map("pay_gap_reports")
}

model JointPayAssessment {
  id            String           @id @default(cuid())
  tenantId      String
  reportId      String?
  triggeredAt   DateTime         @default(now())
  triggerReason String           @db.Text
  status        AssessmentStatus @default(OPEN)
  rootCause     String?          @db.Text
  actionPlan    Json?
  dueDate       DateTime?
  resolvedAt    DateTime?
  createdBy     String

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  report PayGapReport? @relation(fields: [reportId], references: [id])

  @@map("joint_pay_assessments")
}

// ─────────────────────────────────────────
// EMPLOYEE PORTAL (EU 2023/970 Art. 7)
// ─────────────────────────────────────────

model EmployeeRequest {
  id             String        @id @default(cuid())
  tenantId       String
  requestedBy    String
  requestEmail   String
  salaryGradeId  String?
  requestType    String        @default("ART7")
  status         RequestStatus @default(PENDING)
  requestDetails String?       @db.Text
  response       String?       @db.Text
  respondedAt    DateTime?
  respondedBy    String?
  dueDate        DateTime
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salaryGrade SalaryGrade? @relation(fields: [salaryGradeId], references: [id])

  @@map("employee_requests")
}

// ─────────────────────────────────────────
// RAPORT ANGAJAT CONTINUU (document viu transversal)
// ─────────────────────────────────────────

model EmployeeContinuousReport {
  id             String                      @id @default(cuid())
  tenantId       String
  employeeName   String                      // Nume angajat (nu neapărat user)
  employeeEmail  String?
  jobTitle       String?                     // Postul curent
  department     String?
  visibleToEmployee Boolean                  @default(false) // bifă angajator → GDPR Art. 15
  status         ContinuousReportStatus      @default(ACTIVE)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  tenant   Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sections EmployeeReportSection[]

  @@unique([tenantId, employeeEmail])
  @@index([tenantId])
  @@map("employee_continuous_reports")
}

model EmployeeReportSection {
  id        String                   @id @default(cuid())
  reportId  String
  module    ReportModule             // care modul a generat secțiunea
  title     String
  content   Json                     // conținut structurat (diferă per modul)
  order     Int                      @default(0)
  version   Int                      @default(1) // document viu — versiuni
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  report EmployeeContinuousReport    @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, module])
  @@map("employee_report_sections")
}

// ─────────────────────────────────────────
// JURNAL GHID JOBGRADE (feedback loop antrenare)
// ─────────────────────────────────────────

model GuideJournalEntry {
  id         String            @id @default(cuid())
  tenantId   String
  userId     String?
  page       String            // pagina/context
  question   String            @db.Text
  answer     String            @db.Text
  helpful    Boolean?          // feedback: a fost util?
  category   String?           // clasificare automată
  delegatedTo String?          // agentul delegat (SOA, CSSA, etc.)
  createdAt  DateTime          @default(now())

  tenant Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, page])
  @@index([tenantId, category])
  @@map("guide_journal_entries")
}

model ScoreOverride {
  id          String   @id @default(cuid())
  sessionId   String
  jobId       String
  criterionId String
  ownerId     String
  subfactorId String
  rationale   String   @db.Text
  createdAt   DateTime @default(now())

  session   EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  owner     User              @relation(fields: [ownerId], references: [id])
  criterion Criterion         @relation(fields: [criterionId], references: [id])
  subfactor Subfactor         @relation(fields: [subfactorId], references: [id])

  @@map("score_overrides")
}

// ─────────────────────────────────────────
// COMPENSAȚII & SIMULĂRI
// ─────────────────────────────────────────

model CompensationPackage {
  id         String   @id @default(cuid())
  tenantId   String
  jobId      String
  baseSalary Float
