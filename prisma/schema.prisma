enum SeniorityLevel {
  ENTRY // 0-2 ani experiență
  MID // 2-5 ani
  SENIOR // 5-10 ani
  LEAD // 10+ ani, conducere echipă
  EXECUTIVE // C-level, director
}

// ── Dialog-Centric Engine ──────────────────────────────────────────────────

/// Conversation thread — persistent chat history (COG, Team, Assistant)
model ConversationThread {
