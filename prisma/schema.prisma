  tenantId    String
  userId      String
  agentRole   String // COG, HR_COUNSELOR, MEDIATOR, etc.
  threadType  ThreadType @default(ASSISTANT)
  title       String? // Auto-generated summary
  pageContext String? // Page where conversation started
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  messages ConversationMessage[]

  @@index([tenantId, userId, isActive])
  @@index([userId, agentRole])
