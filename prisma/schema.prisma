  category      String   // pricing-internal, algorithm, scoring-formula, strategy
  content       String   @db.Text
  accessLevel   String   @default("INTERNAL_ONLY") // INTERNAL_ONLY | MANAGEMENT | OWNER
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([category])
  @@index([accessLevel])
  @@map("trade_secrets")
}

// ─────────────────────────────────────────
// CRAWLING ENGINE — Shared Infrastructure
// ─────────────────────────────────────────

/// Sursă de date externe (INS, topfirme, primărie, etc.)
model CrawlSource {
  id              String   @id @default(cuid())
  name            String   @unique // ex: "INS_TEMPO", "TOPFIRME", "PRIMARIE_MEDGIDIA"
  displayName     String   // ex: "INS TEMPO Online"
  url             String   // URL bază
  type            String   // API | HTML_SCRAPER | RSS | PDF
  schedule        String   // cron expression: "0 6 * * *" = zilnic la 6
  enabled         Boolean  @default(true)
  territory       String?  // localitate/județ/național — null = toate
  lastCrawlAt     DateTime?
  lastSuccessAt   DateTime?
  lastError       String?  @db.Text
  totalCrawls     Int      @default(0)
  totalRecords    Int      @default(0)
  config          Json?    // configurare specifică per sursă (headers, selectors, etc.)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  results CrawlResult[]

  @@map("crawl_sources")
}

/// Rezultatul unei sesiuni de crawling
model CrawlResult {
  id            String   @id @default(cuid())
  sourceId      String
  crawledAt     DateTime @default(now())
  status        String   // SUCCESS | PARTIAL | FAILED
  recordsFound  Int      @default(0)
  recordsNew    Int      @default(0)
  recordsUpdated Int     @default(0)
  durationMs    Int      @default(0)
  error         String?  @db.Text
  metadata      Json?    // statistici suplimentare per crawl

  source CrawlSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, crawledAt])
  @@map("crawl_results")
}

/// Date teritoriale normalizate (output crawling — consumate de agenți)
model TerritorialData {
  id            String   @id @default(cuid())
  territory     String   // cod SIRUTA sau "MEDGIDIA", "JUD_CONSTANTA", etc.
  category      String   // POPULATION | BUSINESS | INFRASTRUCTURE | EDUCATION | HEALTH | LABOR | ECONOMY
  subcategory   String?  // per categorie: AGE_GROUPS, CAEN_DISTRIBUTION, SCHOOLS, etc.
  key           String   // identificator unic per dată: "pop_20_29", "firms_total", etc.
  value         String   @db.Text // valoare (număr, JSON, text)
  numericValue  Float?   // valoare numerică (pentru comparații/sort)
  unit          String?  // "persoane", "firme", "RON", "%"
  source        String   // CrawlSource.name
  sourceUrl     String?  // URL exact de unde vine
  periodYear    Int?     // anul la care se referă datele
  periodMonth   Int?     // luna (opțional)
  latitude      Float?   // GPS
  longitude     Float?   // GPS
  radius        Float?   // raza de relevanță (km)
  confidence    Float    @default(1.0) // 1.0 = sursă oficială, 0.5 = estimat
  crawledAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([territory, category, key, periodYear])
  @@index([territory, category])
  @@index([category, subcategory])
  @@index([territory])
  @@map("territorial_data")
}

/// Entitate locală (firmă, instituție, serviciu) — GPS-mapped
model LocalEntity {
  id            String   @id @default(cuid())
  territory     String   // MEDGIDIA, etc.
  type          String   // BUSINESS | SCHOOL | HOSPITAL | PHARMACY | SERVICE | PERSON
  name          String
  description   String?  @db.Text
  category      String?  // CAEN, tip serviciu, etc.
  subcategory   String?
  address       String?
  latitude      Float?
  longitude     Float?
  phone         String?
  email         String?
  website       String?
  employees     Int?
  revenue       Float?   // cifră afaceri RON
  source        String   // crawl source sau "CROWDSOURCED"
  sourceId      String?  // CUI, cod unic, etc.
  isActive      Boolean  @default(true)
  isCrowdsourced Boolean @default(false) // true = participant s-a înregistrat singur
  metadata      Json?    // date suplimentare specifice tipului
  crawledAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([territory, type, sourceId])
  @@index([territory, type])
  @@index([territory, latitude, longitude])
  @@index([type, category])
  @@map("local_entities")
}

// ═══════════════════════════════════════════════════════════════
// MOTOR TERITORIAL — PUNȚI (Business #2)
// ═══════════════════════════════════════════════════════════════

/// Participant pe hartă — simultan cumpărător + furnizor
model BridgeParticipant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Identitate (pseudonim, ca în B2C)
  alias     String
  email     String   @unique
  phone     String?

  // Demografie
  ageRange  String?          // "20-29", "30-39" etc.
  gender    String?          // M/F/other

  // Context profesional
  status    ParticipantStatus @default(ANGAJAT)
  hierarchy String?          // EXECUTIE, MIDDLE, TOP
  workplace String?          // localitate loc de muncă (poate diferi de domiciliu)

  // Sfera relațională
  maritalStatus String?
  hasChildren   Boolean  @default(false)
  childrenAges  String?  // "3,7,12"

  // Locație
  territory String          // UAT domiciliu
  address   String?
  latitude  Float?
  longitude Float?
  searchRadius Float @default(15) // km — raza de căutare implicită

  // Scoring intern
  profileCompleteness Float @default(0) // 0-1
  lastActiveAt DateTime?

  // Relații
  needs     BridgeNeed[]
  offers    BridgeOffer[]
  connectionsAsClient   BridgeConnection[] @relation("ConnectionClient")
  connectionsAsProvider BridgeConnection[] @relation("ConnectionProvider")
  reports   BridgeReport[]

  @@index([territory])
  @@index([territory, latitude, longitude])
  @@map("bridge_participants")
}

enum ParticipantStatus {
  ANGAJAT
  LIBER_PROFESIONIST
  SOMER
  PENSIONAR
  STUDENT
  ANTREPRENOR
}

/// Ce are nevoie participantul (punct de cerere pe hartă)
model BridgeNeed {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participantId String
  participant   BridgeParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  // Categorizare (sector → nișă din taxonomie)
  sectorId  String           // TURISM, SANATATE, EDUCATIE etc.
  nicheId   String?          // SAN_PRIMARA, EDU_FORMARE_PROF etc.
  category  String           // categorie liberă (ex: "stomatologie", "formare IT")

  // Detalii
  description String?        // ce anume are nevoie
  urgency     NeedUrgency @default(NORMAL)
  frequency   String?        // "o dată", "lunar", "săptămânal"
  budget      String?        // "sub 100 RON", "100-500 RON", "nu contează"

  // Preferințe
  preferLocal   Boolean @default(true)   // preferă furnizor local
  acceptOnline  Boolean @default(false)  // acceptă și online
  maxDistanceKm Float?                   // distanță maximă acceptabilă

  // Status
  isActive    Boolean @default(true)
  isSatisfied Boolean @default(false)    // nevoia a fost acoperită

  // Relații
  connections BridgeConnection[]

  @@index([participantId])
  @@index([sectorId, nicheId])
  @@index([isActive, territory])
  @@map("bridge_needs")

  // Virtual — territory vine din participant
  territory String?
}

enum NeedUrgency {
  CRITIC       // trebuie acum
  URGENT       // în câteva zile
  NORMAL       // în câteva săptămâni
  PLANIFICAT   // pe viitor
}

/// Ce oferă participantul (punct de ofertă pe hartă)
model BridgeOffer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participantId String
  participant   BridgeParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  // Categorizare
  sectorId  String
  nicheId   String?
  category  String           // ce oferă concret

  // Detalii ofertă
  description   String?      // descriere serviciu/produs
  priceRange    String?      // "50-100 RON", "negociabil", "gratuit"
  priceUnit     String?      // "pe oră", "pe ședință", "pe bucată"

  // Disponibilitate
  availableFrom String?      // program ("L-V 9-17", "flexibil")
  deliveryType  DeliveryType @default(LOCAL)
  coverageKm    Float?       // raza de acoperire (km)
  isOnline      Boolean @default(false) // oferă și online

  // Calitate
  experienceYears Int?       // ani experiență
  certifications  String?    // certificări relevante
  qualityScore    Float?     // 0-5, din feedback clienți

  // Status
  isActive    Boolean @default(true)
  capacity    String?        // "max 5 clienți/săptămână"

  // Relații
  connections BridgeConnection[]

  @@index([participantId])
  @@index([sectorId, nicheId])
  @@index([isActive, deliveryType])
  @@map("bridge_offers")

  territory String?
}

enum DeliveryType {
  LOCAL        // la sediul furnizorului
  DEPLASARE    // furnizorul vine la client
  ONLINE       // remote/digital
  LIVRARE      // produs livrat fizic
  MIXT         // combinație
}

/// Punte — conexiune concretă cerere↔ofertă
model BridgeConnection {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Părți
  clientId    String
  client      BridgeParticipant @relation("ConnectionClient", fields: [clientId], references: [id])
  providerId  String
  provider    BridgeParticipant @relation("ConnectionProvider", fields: [providerId], references: [id])

  // Ce se conectează
  needId    String
  need      BridgeNeed @relation(fields: [needId], references: [id])
  offerId   String
  offer     BridgeOffer @relation(fields: [offerId], references: [id])

  // Matching
  matchScore    Float        // 0-1, cât de bun e match-ul
  distanceKm    Float?       // distanța fizică între client și furnizor
  matchReason   String?      // de ce a fost recomandat

  // Status flux
  status    ConnectionStatus @default(PROPOSED)
  proposedAt  DateTime @default(now())
  viewedAt    DateTime?      // clientul a văzut propunerea
  acceptedAt  DateTime?      // una din părți a acceptat
  completedAt DateTime?      // tranzacția s-a finalizat
  rejectedAt  DateTime?
  rejectionReason String?

  // Feedback (după completare)
  clientRating    Int?       // 1-5
  clientComment   String?
  providerRating  Int?       // 1-5
  providerComment String?

  @@index([clientId, status])
  @@index([providerId, status])
  @@index([needId])
  @@index([offerId])
  @@index([status])
  @@map("bridge_connections")
}

enum ConnectionStatus {
  PROPOSED     // motorul a propus match-ul
  VIEWED       // clientul a văzut
  ACCEPTED     // una din părți a acceptat
  IN_PROGRESS  // tranzacție în curs
  COMPLETED    // finalizat cu succes
  REJECTED     // refuzat
  EXPIRED      // expirat fără răspuns
}

/// Raport gratuit generat la onboarding
model BridgeReport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  participantId String
  participant   BridgeParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  territory String

  // Conținut raport (JSON structurat)
  needs          Json       // nevoi identificate din profil
  localProviders Json       // furnizori locali existenți
  gaps           Json       // ce lipsește în zonă
  recommendations Json      // recomandări personalizate
  opportunities  Json?      // oportunități dacă e furnizor

  // Metadata
  generatedBy String @default("AI")  // AI sau manual
  version     Int    @default(1)

  @@index([participantId])
  @@index([territory])
  @@map("bridge_reports")
}

// ═══════════════════════════════════════════════════════════════
// VITAL SIGNS — Rapoarte sănătate organism (istoric)
// ═══════════════════════════════════════════════════════════════

model VitalSignsReport {
  id            String   @id @default(cuid())
  reportDate    DateTime @default(now())

  overallStatus String   // CRITICAL, WARNING, HEALTHY

  passCount     Int      @default(0)
  warnCount     Int      @default(0)
  failCount     Int      @default(0)
  skipCount     Int      @default(0)

  /// Raport complet (tests[], metrics, notes)
  fullReport    Json

  createdAt     DateTime @default(now())

  checks VitalSignsCheck[]

  @@index([reportDate])
  @@index([overallStatus])
  @@map("vital_signs_reports")
}

model VitalSignsCheck {
  id            String   @id @default(cuid())
  reportId      String

  componentName String   // ex: "Puls", "Respirație", "Conștiință"
  status        String   // PASS, WARN, FAIL, SKIP
  detail        String
  metric        Float?

  report VitalSignsReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([componentName])
  @@map("vital_signs_checks")
}
