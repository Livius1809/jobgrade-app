  gradeMax Int? // gradul maxim echivalent (1-8)

  // Date salariale (brut lunar RON)
  salaryP10    Float? // percentila 10
  salaryP25    Float // percentila 25 (Q1)
  salaryMedian Float // mediana (P50)
  salaryP75    Float // percentila 75 (Q3)
  salaryP90    Float? // percentila 90
