  tenureOrg      Float        @default(0) // vechime organizație (ani)
  tenureRole     Float        @default(0) // vechime post (ani)
  workLocation   WorkLocation // sediu/remote/hibrid
  city           String // localitate
  education      Education // studii
  certifications String? // certificări/atestări profesionale

  // Calculat automat
  totalMonthlyGross Float? // salariu total lunar brut (normalizat la 8h)
