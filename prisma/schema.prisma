generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// TENANCY & AUTH
// ─────────────────────────────────────────

model Tenant {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  plan             Plan         @default(STARTER)
  locale           String       @default("ro")
  status           TenantStatus @default(ACTIVE)
  stripeCustomerId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  users                 User[]
  company               CompanyProfile?
  departments           Department[]
  jobs                  Job[]
  sessions              EvaluationSession[]
  compensationPkgs      CompensationPackage[]
  kpiDefinitions        KpiDefinition[]
  simulations           SimulationScenario[]
  aiGenerations         AiGeneration[]
  reports               Report[]
  credits               CreditBalance?
  creditTxns            CreditTransaction[]
  salaryGrades          SalaryGrade[]
  employeeSalaryRecords EmployeeSalaryRecord[]
  payGapReports         PayGapReport[]
  jointAssessments      JointPayAssessment[]
  employeeRequests      EmployeeRequest[]
  clientMemories        ClientMemory[]

  @@map("tenants")
}

model User {
  id           String     @id @default(cuid())
  tenantId     String
  email        String
  passwordHash String?
  firstName    String
  lastName     String
  jobTitle     String?
  role         UserRole   @default(REPRESENTATIVE)
  locale       String     @default("ro")
  lastLogin    DateTime?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?

  accounts                 Account[]
  authSessions             AuthSession[]
  sessionParticipants      SessionParticipant[]
  jobAssignments           JobAssignment[]
  votes                    Vote[]
  facilitatorDecisions     FacilitatorDecision[]
  clarificationQuestions   ClarificationQuestion[]
  clarificationAnswers     ClarificationAnswer[]
  overrides                ScoreOverride[]
  notifications            Notification[]
  representedJobs          Job[]                  @relation("JobRepresentative")

  @@unique([tenantId, email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────
// COMPANY PROFILE
// ─────────────────────────────────────────

model CompanyProfile {
  id          String    @id @default(cuid())
  tenantId    String    @unique
  mission     String?   @db.Text
  vision      String?   @db.Text
  values      String[]
  description String?   @db.Text
  industry    String?
  size        String?
  website     String?
  cui         String?
  regCom      String?
  address     String?
  county      String?
  logoUrl     String?
  extractedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("company_profiles")
}

model Department {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[]
  jobs   Job[]

  @@unique([tenantId, name])
  @@map("departments")
}

// ─────────────────────────────────────────
// FIȘE DE POST
// ─────────────────────────────────────────

model Job {
  id               String    @id @default(cuid())
  tenantId         String
  departmentId     String?
  representativeId String?
  title            String
  code             String?
  purpose          String?   @db.Text
  description      String?   @db.Text
  responsibilities String?   @db.Text
  requirements     String?   @db.Text
  status           JobStatus @default(DRAFT)
  isActive         Boolean   @default(true)
  aiAnalyzed       Boolean   @default(false)
  aiAnalysis       Json?
  createdBy        String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department     Department? @relation(fields: [departmentId], references: [id])
  representative User?       @relation("JobRepresentative", fields: [representativeId], references: [id])

  sessionJobs          SessionJob[]
  compensationPackages CompensationPackage[]
  kpiDefinitions       KpiDefinition[]
  simulations          SimulationScenario[]
  jobResults           JobResult[]

  @@map("jobs")
}

// ─────────────────────────────────────────
// CRITERII (GLOBALE — definite de platformă)
// ─────────────────────────────────────────

model Criterion {
  id          String  @id @default(cuid())
  name        String  @unique
  description String? @db.Text
  category    String?
  order       Int
  isActive    Boolean @default(true)

  subfactors           Subfactor[]
  evaluations          Evaluation[]
  consensusStatuses    ConsensusStatus[]
  votes                Vote[]
  facilitatorDecisions FacilitatorDecision[]
  overrides            ScoreOverride[]

  @@map("criteria")
}

model Subfactor {
  id          String @id @default(cuid())
  criterionId String
  code        String
  description String @db.Text
  points      Int
  order       Int

  criterion            Criterion             @relation(fields: [criterionId], references: [id])
  evaluations          Evaluation[]
  votes                Vote[]
  facilitatorDecisions FacilitatorDecision[]
  overrides            ScoreOverride[]
  consensuses          ConsensusStatus[]

  @@unique([criterionId, code])
  @@map("subfactors")
}

// ─────────────────────────────────────────
// SESIUNI DE EVALUARE
// ─────────────────────────────────────────

model EvaluationSession {
  id                 String        @id @default(cuid())
  tenantId           String
  name               String
  status             SessionStatus @default(DRAFT)
  currentRound       Int           @default(1)
  consensusThreshold Float         @default(0.75)
  deadline           DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  createdById        String        @default("")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sessionJobs          SessionJob[]
  participants         SessionParticipant[]
  evaluations          Evaluation[]
  consensusStatuses    ConsensusStatus[]
  votes                Vote[]
  facilitatorDecisions FacilitatorDecision[]
  clarifications       ClarificationQuestion[]
  jobResults           JobResult[]
  salaryGrades         SalaryGrade[]
  overrides            ScoreOverride[]

  @@map("evaluation_sessions")
}

model SessionJob {
  id        String   @id @default(cuid())
  sessionId String
  jobId     String
  createdAt DateTime @default(now())

  session     EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id])
  assignments JobAssignment[]

  @@unique([sessionId, jobId])
  @@map("session_jobs")
}

model SessionParticipant {
  id          String    @id @default(cuid())
  sessionId   String
  userId      String
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  session EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@map("session_participants")
}

model JobAssignment {
  id           String    @id @default(cuid())
  sessionJobId String
  userId       String
  submittedAt  DateTime?
  createdAt    DateTime  @default(now())

  sessionJob  SessionJob  @relation(fields: [sessionJobId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])
  evaluations Evaluation[]

  @@unique([sessionJobId, userId])
  @@map("job_assignments")
}

// ─────────────────────────────────────────
// EVALUARE / SCORARE
// ─────────────────────────────────────────

model Evaluation {
  id            String   @id @default(cuid())
  sessionId     String
  assignmentId  String
  criterionId   String
  subfactorId   String
  justification String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  session    EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assignment JobAssignment     @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  criterion  Criterion         @relation(fields: [criterionId], references: [id])
  subfactor  Subfactor         @relation(fields: [subfactorId], references: [id])

  @@unique([assignmentId, criterionId])
  @@map("evaluations")
}

// ─────────────────────────────────────────
// CLARIFICĂRI
// ─────────────────────────────────────────

model ClarificationQuestion {
  id          String   @id @default(cuid())
  sessionId   String
  jobId       String
  criterionId String
  question    String   @db.Text
  askedBy     String
  createdAt   DateTime @default(now())

  session EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  asker   User              @relation(fields: [askedBy], references: [id])
  answer  ClarificationAnswer?

  @@map("clarification_questions")
}

model ClarificationAnswer {
  id         String   @id @default(cuid())
  questionId String   @unique
  answer     String   @db.Text
  answeredBy String
  createdAt  DateTime @default(now())

  question ClarificationQuestion @relation(fields: [questionId], references: [id])
  answerer User                  @relation(fields: [answeredBy], references: [id])

  @@map("clarification_answers")
}

// ─────────────────────────────────────────
// CONSENS
// ─────────────────────────────────────────

model ConsensusStatus {
  id               String         @id @default(cuid())
  sessionId        String
  jobId            String
  criterionId      String
  status           ConsensusState @default(PENDING)
  round1Cv         Float?
  round2Cv         Float?
  finalSubfactorId String?
  updatedAt        DateTime       @updatedAt

  session        EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  criterion      Criterion         @relation(fields: [criterionId], references: [id])
  finalSubfactor Subfactor?        @relation(fields: [finalSubfactorId], references: [id])

  @@unique([sessionId, jobId, criterionId])
  @@map("consensus_statuses")
}

model Vote {
  id          String   @id @default(cuid())
  sessionId   String
  jobId       String
  criterionId String
  userId      String
  subfactorId String
  createdAt   DateTime @default(now())

  session   EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id])
  criterion Criterion         @relation(fields: [criterionId], references: [id])
  subfactor Subfactor         @relation(fields: [subfactorId], references: [id])

  @@unique([sessionId, jobId, criterionId, userId])
  @@map("votes")
}

model FacilitatorDecision {
  id            String   @id @default(cuid())
  sessionId     String
  jobId         String
  criterionId   String
  facilitatorId String
  subfactorId   String
  rationale     String   @db.Text
  createdAt     DateTime @default(now())

  session     EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  facilitator User              @relation(fields: [facilitatorId], references: [id])
  criterion   Criterion         @relation(fields: [criterionId], references: [id])
  subfactor   Subfactor         @relation(fields: [subfactorId], references: [id])

  @@unique([sessionId, jobId, criterionId])
  @@map("facilitator_decisions")
}

// ─────────────────────────────────────────
// REZULTATE & CLASIFICARE
// ─────────────────────────────────────────

model JobResult {
  id              String   @id @default(cuid())
  sessionId       String
  jobId           String
  totalScore      Int
  normalizedScore Float
  rank            Int
  salaryGradeId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  session     EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  job         Job               @relation(fields: [jobId], references: [id])
  salaryGrade SalaryGrade?      @relation(fields: [salaryGradeId], references: [id])

  @@unique([sessionId, jobId])
  @@map("job_results")
}

model SalaryGrade {
  id        String   @id @default(cuid())
  tenantId  String
  sessionId String
  name      String
  scoreMin  Int
  scoreMax  Int
  salaryMin Float?
  salaryMax Float?
  currency  String   @default("RON")
  order     Int
  createdAt DateTime @default(now())

  tenant               Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session              EvaluationSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  jobResults           JobResult[]
  employeeSalaryRecords EmployeeSalaryRecord[]
  employeeRequests     EmployeeRequest[]

  @@map("salary_grades")
}

// ─────────────────────────────────────────
// PAY GAP ANALYTICS (EU 2023/970 Art. 9)
// ─────────────────────────────────────────

model EmployeeSalaryRecord {
  id            String   @id @default(cuid())
  tenantId      String
  salaryGradeId String?
  employeeCode  String
  gender        Gender
  baseSalary    Float
  variableComp  Float    @default(0)
  department    String?
  jobCategory   String?
  periodYear    Int
  periodMonth   Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salaryGrade SalaryGrade? @relation(fields: [salaryGradeId], references: [id])

  @@unique([tenantId, employeeCode, periodYear])
  @@map("employee_salary_records")
}

model PayGapReport {
  id            String       @id @default(cuid())
  tenantId      String
  reportYear    Int
  indicators    Json
  employeeCount Int
  status        ReportStatus @default(DRAFT)
  publishedAt   DateTime?
  generatedAt   DateTime     @default(now())
  generatedBy   String

  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jointAssessments JointPayAssessment[]

  @@unique([tenantId, reportYear])
  @@map("pay_gap_reports")
}

model JointPayAssessment {
  id            String           @id @default(cuid())
  tenantId      String
  reportId      String?
  triggeredAt   DateTime         @default(now())
  triggerReason String           @db.Text
  status        AssessmentStatus @default(OPEN)
  rootCause     String?          @db.Text
  actionPlan    Json?
  dueDate       DateTime?
  resolvedAt    DateTime?
  createdBy     String

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  report PayGapReport? @relation(fields: [reportId], references: [id])

  @@map("joint_pay_assessments")
}

// ─────────────────────────────────────────
// EMPLOYEE PORTAL (EU 2023/970 Art. 7)
// ─────────────────────────────────────────

model EmployeeRequest {
  id             String        @id @default(cuid())
  tenantId       String
  requestedBy    String
  requestEmail   String
  salaryGradeId  String?
  requestType    String        @default("ART7")
  status         RequestStatus @default(PENDING)
  requestDetails String?       @db.Text
  response       String?       @db.Text
  respondedAt    DateTime?
  respondedBy    String?
  dueDate        DateTime
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salaryGrade SalaryGrade? @relation(fields: [salaryGradeId], references: [id])

  @@map("employee_requests")
}

model ScoreOverride {
  id          String   @id @default(cuid())
  sessionId   String
  jobId       String
  criterionId String
  ownerId     String
  subfactorId String
  rationale   String   @db.Text
  createdAt   DateTime @default(now())

  session   EvaluationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  owner     User              @relation(fields: [ownerId], references: [id])
  criterion Criterion         @relation(fields: [criterionId], references: [id])
  subfactor Subfactor         @relation(fields: [subfactorId], references: [id])

  @@map("score_overrides")
}

// ─────────────────────────────────────────
// COMPENSAȚII & SIMULĂRI
// ─────────────────────────────────────────

model CompensationPackage {
  id         String   @id @default(cuid())
  tenantId   String
  jobId      String
  baseSalary Float
  currency   String   @default("RON")
  components Json
  benefits   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job         Job                  @relation(fields: [jobId], references: [id])
  simulations SimulationScenario[]

  @@map("compensation_packages")
}

model KpiDefinition {
  id              String       @id @default(cuid())
  tenantId        String
  jobId           String
  name            String
  weight          Float
  targetValue     Float
  measurementUnit String
  frequency       KpiFrequency @default(MONTHLY)
  createdAt       DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job    Job    @relation(fields: [jobId], references: [id])

  @@map("kpi_definitions")
}

model SimulationScenario {
  id               String   @id @default(cuid())
  tenantId         String
  jobId            String
  packageId        String
  name             String
  kpiAchievements  Json
  calculatedResult Json
  createdBy        String
  createdAt        DateTime @default(now())

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job     Job                 @relation(fields: [jobId], references: [id])
  package CompensationPackage @relation(fields: [packageId], references: [id])

  @@map("simulation_scenarios")
}

// ─────────────────────────────────────────
// AI GENERĂRI
// ─────────────────────────────────────────

model AiGeneration {
  id         String          @id @default(cuid())
  tenantId   String
  type       AiGenerationType
  sourceId   String?
  sourceType String?
  prompt     String          @db.Text
  output     String          @db.Text
  model      String
  tokensUsed Int
  credits    Int
  createdAt  DateTime        @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ai_generations")
}

// ─────────────────────────────────────────
// RAPOARTE
// ─────────────────────────────────────────

model Report {
  id          String       @id @default(cuid())
  tenantId    String
  sessionId   String?
  type        ReportType
  format      ReportFormat
  sections    String[]
  locale      String       @default("ro")
  filePath    String?
  generatedBy String
  createdAt   DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("reports")
}

// ─────────────────────────────────────────
// CREDITE & BILLING
// ─────────────────────────────────────────

model CreditBalance {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("credit_balances")
}

model CreditTransaction {
  id          String        @id @default(cuid())
  tenantId    String
  type        CreditTxnType
  amount      Int
  description String
  sourceId    String?
  createdAt   DateTime      @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("credit_transactions")
}

// ─────────────────────────────────────────
// NOTIFICĂRI
// ─────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────
// KNOWLEDGE BASE (KB)
// ─────────────────────────────────────────

model KBEntry {
  id             String    @id @default(cuid())
  agentRole      String    // ex: "HR_COUNSELOR", "PSYCHOLINGUIST"
  kbType         KBType
  content        String    @db.Text
  embedding      Unsupported("vector(1536)")?
  source         KBSource
  confidence     Float     @default(0)
  usageCount     Int       @default(0)
  successRate    Float?
  status         KBStatus  @default(BUFFER)
  tags           String[]
  createdAt      DateTime  @default(now())
  validatedAt    DateTime?
  propagatedFrom String?   // agentRole sursă dacă e propagat

  @@index([agentRole, status])
  @@index([agentRole, kbType])
  @@map("kb_entries")
}

model KBBuffer {
  id               String   @id @default(cuid())
  agentRole        String
  rawContent       String   @db.Text
  sessionRef       String?
  occurrences      Int      @default(1)
  positiveOutcomes Int      @default(0)
  totalOutcomes    Int      @default(0)
  status           String   @default("PENDING") // PENDING|APPROVED|REJECTED
  createdAt        DateTime @default(now())
  reviewedAt       DateTime?

  @@index([agentRole, status])
  @@map("kb_buffers")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Plan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  OWNER
  FACILITATOR
  REPRESENTATIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum JobStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SessionStatus {
  DRAFT
  IN_PROGRESS
  RECALIBRATION
  VOTING
  FACILITATION
  COMPLETED
}

enum ConsensusState {
  PENDING
  CONSENSUS
  RECALIBRATING
  VOTING
  FACILITATED
  RESOLVED
}

enum KpiFrequency {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum AiGenerationType {
  JOB_AD
  SOCIAL_MEDIA
  KPI_SHEET
  SESSION_ANALYSIS
  JOB_ANALYSIS
  COMPANY_EXTRACT
}

enum ReportType {
  HIERARCHY
  SALARY_GRADES
  KPI
  BUDGET
  FULL
}

enum ReportFormat {
  PDF
  EXCEL
}

enum CreditTxnType {
  PURCHASE
  SUBSCRIPTION_MONTHLY
  USAGE
  REFUND
}

enum NotificationType {
  SESSION_LAUNCHED
  EVALUATOR_COMPLETED
  ALL_COMPLETED
  CONSENSUS_REACHED
  RECALIBRATION_STARTED
  VOTE_STARTED
  FACILITATOR_NEEDED
  CLARIFICATION_RECEIVED
  CLARIFICATION_ANSWERED
  REPORT_GENERATED
  CREDITS_LOW
  INVOICE_ISSUED
  EMPLOYEE_REQUEST_RECEIVED
  EMPLOYEE_REQUEST_OVERDUE
  PAY_GAP_THRESHOLD_EXCEEDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ReportStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AssessmentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum RequestStatus {
  PENDING
  IN_REVIEW
  RESPONDED
  OVERDUE
}

enum KBType {
  PERMANENT       // KB personal al agentului
  SHARED_DOMAIN   // KB domeniu partajat (ex: HR general)
  CLIENT_LEXICON  // lexicon extras din docs client
  METHODOLOGY     // metodologia JobGrade — read-only
}

enum KBSource {
  SELF_INTERVIEW        // pre-populare via Claude self-interview
  EXPERT_HUMAN          // input direct de la fondatori
  DISTILLED_INTERACTION // distilat din sesiuni reale
  PROPAGATED            // primit de la alt agent
}

enum KBStatus {
  BUFFER    // nevalidat încă
  PERMANENT // validat, activ
  ARCHIVED  // deprecat
}

// ── Proactive Management ──────────────────────────────────────────────────────

model CycleLog {
  id            String   @id @default(cuid())
  managerRole   String
  targetRole    String
  actionType    String   // TRACK, INTERVENE, ESCALATE
  description   String   @db.Text
  details       String?  @db.Text
  escalationId  String?
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?

  @@index([managerRole, resolved])
  @@index([targetRole, actionType])
  @@map("cycle_logs")
}

model Escalation {
  id              String    @id @default(cuid())
  externalId      String    @unique // ESC-timestamp-random
  sourceRole      String
  targetRole      String
  aboutRole       String
  reason          String    @db.Text
  details         String?   @db.Text
  priority        String    // CRITICAL, HIGH, MEDIUM, LOW
  status          String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, ESCALATED_UP, TIMEOUT
  resolution      String?   @db.Text
  timeoutHours    Int       @default(24)
  escalatedFromId String?   // ID escalare anterioară
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  resolvedAt      DateTime?

  @@index([targetRole, status])
  @@index([sourceRole, status])
  @@index([status])
  @@map("escalations")
}

// ── Agent Registry (dynamic org chart) ───────────────────────────────────────

model AgentDefinition {
  id                   String     @id @default(cuid())
  agentRole            String     @unique
  displayName          String
  description          String     @db.Text
  level                AgentLevel
  isManager            Boolean    @default(false)
  isActive             Boolean    @default(true)

  // Manager-specific
  cycleIntervalHours   Int?
  objectives           String[]
  thresholds           Json?

  // Cold start config
  coldStartDescription String?    @db.Text
  coldStartPrompts     String[]

  // Propagation rules (outgoing edges)
  propagationTargets   Json?

  // Metadata
  createdBy            String     @default("SYSTEM")
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  parentRelations      AgentRelationship[] @relation("ChildAgent")
  childRelations       AgentRelationship[] @relation("ParentAgent")
  proposals            OrgProposal[]       @relation("ProposalAgent")
  metrics              AgentMetric[]

  @@index([level, isActive])
  @@map("agent_definitions")
}

model AgentRelationship {
  id           String       @id @default(cuid())
  parentRole   String
  childRole    String
  relationType RelationType @default(REPORTS_TO)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())

  parent       AgentDefinition @relation("ParentAgent", fields: [parentRole], references: [agentRole])
  child        AgentDefinition @relation("ChildAgent", fields: [childRole], references: [agentRole])

  @@unique([parentRole, childRole])
  @@index([parentRole, isActive])
  @@map("agent_relationships")
}

model OrgProposal {
  id              String          @id @default(cuid())
  proposalType    ProposalType
  status          ProposalStatus  @default(DRAFT)
  proposedBy      String
  title           String
  description     String          @db.Text
  rationale       String          @db.Text
  impact          Json?
  changeSpec      Json

  reviewedByCog   Boolean         @default(false)
  cogComment      String?         @db.Text
  ownerDecision   OwnerDecision?
  ownerComment    String?         @db.Text

  executedAt      DateTime?
  rollbackAt      DateTime?

  agentRole       String?
  agent           AgentDefinition? @relation("ProposalAgent", fields: [agentRole], references: [agentRole])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([proposedBy])
  @@map("org_proposals")
}

model AgentMetric {
  id                String   @id @default(cuid())
  agentRole         String
  periodStart       DateTime
  periodEnd         DateTime

  tasksCompleted    Int      @default(0)
  tasksEscalated    Int      @default(0)
  avgResponseTimeMs Int?
  kbEntriesAdded    Int      @default(0)
  kbEntriesUsed     Int      @default(0)
  propagationsOut   Int      @default(0)
  propagationsIn    Int      @default(0)
  healthScoreAvg    Float?
  cycleActions      Int      @default(0)
  performanceScore  Float?

  createdAt         DateTime @default(now())

  agent             AgentDefinition @relation(fields: [agentRole], references: [agentRole])

  @@unique([agentRole, periodStart, periodEnd])
  @@index([agentRole, periodStart])
  @@map("agent_metrics")
}

// ── Agent Registry Enums ─────────────────────────────────────────────────────

enum AgentLevel {
  STRATEGIC
  TACTICAL
  OPERATIONAL
}

enum RelationType {
  REPORTS_TO
  COLLABORATES_WITH
}

enum ProposalType {
  ADD_AGENT
  REMOVE_AGENT
  MERGE_AGENTS
  MODIFY_HIERARCHY
  MODIFY_OBJECTIVES
  MODIFY_PROPAGATION
}

enum ProposalStatus {
  DRAFT
  PROPOSED
  COG_REVIEWED
  OWNER_PENDING
  APPROVED
  REJECTED
  EXECUTING
  EXECUTED
  ROLLED_BACK
}

enum OwnerDecision {
  APPROVED
  REJECTED
  DEFERRED
}

// ── Brainstorming ────────────────────────────────────────────────────────────

model BrainstormSession {
  id              String              @id @default(cuid())
  initiatedBy     String                               // agentRole care a inițiat
  level           AgentLevel                            // OPERATIONAL, TACTICAL, STRATEGIC
  topic           String              @db.Text          // problema/obiectivul de rezolvat
  context         String?             @db.Text          // context adițional (obiective, constrângeri)
  status          BrainstormStatus    @default(GENERATING)
  participantRoles String[]                             // agenții care participă

  // Agregare
  aggregatedFromId String?                              // dacă e sesiune agregată, ID-ul sesiunii sursă
  aggregatedToId   String?                              // dacă a fost agregată într-o sesiune superioară
  proposalId       String?                              // OrgProposal generat (dacă există)

  createdAt       DateTime            @default(now())
  completedAt     DateTime?

  ideas           BrainstormIdea[]

  @@index([initiatedBy, status])
  @@index([level, status])
  @@map("brainstorm_sessions")
}

model BrainstormIdea {
  id              String           @id @default(cuid())
  sessionId       String
  generatedBy     String                               // agentRole care a generat ideea
  title           String
  description     String           @db.Text
  category        String?                              // feature, process, restructure, tool, etc.

  // Scoruri pe 6 criterii (0-100)
  viability       Float?                               // viabilitate implementare
  alignment       Float?                               // aliniere cu obiectivele
  marketFit       Float?                               // oportunitate de piață
  costBenefit     Float?                               // raport cost/beneficii
  easeOfImpl      Float?                               // ușurință implementare
  timeToValue     Float?                               // rapiditate (time-to-value)

  // Scor agregat (media ponderată)
  compositeScore  Float?
  rank            Int?                                 // poziția în sesiune
  scoringRationale String?         @db.Text             // explicația AI a scorurilor

  // Status
  status          IdeaStatus       @default(PROPOSED)
  promotedToLevel String?                              // dacă a fost promovată la nivel superior

  createdAt       DateTime         @default(now())

  session         BrainstormSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, compositeScore])
  @@index([generatedBy])
  @@map("brainstorm_ideas")
}

enum BrainstormStatus {
  GENERATING       // se generează idei
  EVALUATING       // se evaluează/scorează
  EVALUATED        // scorare completă
  AGGREGATING      // se agregează la nivel superior
  AGGREGATED       // trimisă la nivel superior
  OWNER_REVIEW     // la Owner pentru decizie
  CLOSED           // finalizată
}

enum IdeaStatus {
  PROPOSED         // generată
  SCORED           // evaluată pe criterii
  SHORTLISTED      // selectată pentru nivel superior
  PROMOTED         // promovată la nivel superior
  APPROVED         // aprobată de Owner
  REJECTED         // respinsă
  IMPLEMENTED      // implementată (legată de OrgProposal)
}

// ── Client Memory (relație personalizată per client) ─────────────────────────

model ClientMemory {
  id          String          @id @default(cuid())
  tenantId    String                              // clientul (Tenant)
  category    ClientMemoryCategory
  content     String          @db.Text            // ce s-a observat/învățat
  source      String                              // agentRole care a generat
  importance  Float           @default(0.5)       // 0-1, cât de relevant e
  tags        String[]
  expiresAt   DateTime?                           // unele memorii expiră (ex: "e în vacanță")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, category])
  @@index([tenantId, importance])
  @@map("client_memories")
}

// ── External Resources (dependențe Owner) ────────────────────────────────────

model ExternalResource {
  id              String             @id @default(cuid())
  name            String                                // "Anthropic API", "Neon.tech DB", "Domeniu jobgrade.ro"
  category        ResourceCategory
  provider        String                                // "Anthropic", "Neon.tech", "Namecheap"
  status          ResourceStatus     @default(ACTIVE)

  // Cost & billing
  monthlyCost     Float?                                // EUR
  billingCycle    String?                               // "monthly", "annual"
  nextPaymentDate DateTime?

  // Expiry & renewal
  expiresAt       DateTime?                             // când expiră (domeniu, certificat, API key)
  alertDaysBefore Int                @default(14)       // cu câte zile înainte alertăm

  // Status
  lastCheckedAt   DateTime?
  notes           String?            @db.Text

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([nextPaymentDate])
  @@map("external_resources")
}

enum ResourceCategory {
  API_SERVICE       // Anthropic, Resend, Stripe
  INFRASTRUCTURE    // Neon.tech, Vercel, Docker
  DOMAIN            // jobgrade.ro
  CERTIFICATE       // SSL
  SUBSCRIPTION      // n8n cloud, monitoring
  LICENSE           // software licenses
  OTHER
}

enum ResourceStatus {
  ACTIVE
  EXPIRING_SOON     // < alertDaysBefore
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum ClientMemoryCategory {
  PREFERENCE        // cum preferă să comunice, ce formate vrea
  RELATIONSHIP      // cine e contactul principal, decidentul, influencerul
  CONTEXT           // restructurare, M&A, sezon de buget, etc.
  PAIN_POINT        // nemulțumiri, frustrări, probleme recurente
  OPPORTUNITY       // upsell, cross-sell, expansiune
  HISTORY           // ce s-a discutat, ce s-a promis, ce s-a livrat
  STYLE             // formal/informal, detaliat/sumar, RO/EN
}
