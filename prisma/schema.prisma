model SalaryBenchmark {
  id           String          @id @default(cuid())
  source       BenchmarkSource
  sourceDetail String? // "INS 2025 Q4", "Glassdoor Jan 2026"
  year         Int // anul datelor
  quarter      Int? // Q1-Q4 (opțional)
  country      String          @default("RO") // ISO 3166-1 alpha-2

  // Identificare ocupație
  jobFamily      String // "IT", "Financiar", "Vanzari", "HR", etc.
  jobTitle       String? // titlu specific (opțional)
  corCode        String? // Cod COR (Clasificarea Ocupatiilor din Romania)
